# Copy this file to .env and adjust values for your VPS.
# All variables are optional — defaults are shown below.

# Maximum accepted STEP file size in bytes (default: 50 MB)
MAX_FILE_SIZE=52428800

# FreeCAD subprocess timeout in seconds (default: 60)
TIMEOUT_SECONDS=60

# Mesh quality — lower linear deflection = finer mesh, slower conversion
# LINEAR_DEFLECTION is in mm; ANGULAR_DEFLECTION is in degrees
LINEAR_DEFLECTION=0.1
ANGULAR_DEFLECTION=0.5

# Path to the freecadcmd binary
# apt install:   /usr/bin/freecadcmd
# AppImage:      /opt/squashfs-root/usr/bin/FreeCADCmd
FREECADCMD_PATH=/usr/bin/freecadcmd

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
